# 本番（Vercel 等）で設定する環境変数のサンプル。
# このファイルはコミットされるが、実値は .env.local や Vercel の環境変数に入れる（.env*.local は gitignore 対象）。

# --- データベース（Turso / libSQL） ---
# 未設定ならローカルの file:data/teleapo.db を使う。
# 本番では Turso で作成したDBの接続情報を設定する。
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- チーム共通パスワード（アクセス制限） ---
# 設定するとサイト全体がパスワードゲートで保護される（端末ごとに初回1回だけ入力）。
# 未設定ならゲートなし（ローカル開発はこちら）。
SITE_PASSWORD=set-a-shared-password
